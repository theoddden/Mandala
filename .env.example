MANDALA_REDIS_URL=redis://localhost:6379/0
MANDALA_DATABASE_URL=postgresql+asyncpg://mandala:mandala@localhost:5432/mandala

# Webhook HMAC secrets (configure in Samsara/Descartes admin consoles)
MANDALA_SAMSARA_WEBHOOK_SECRET=replace-me
MANDALA_DESCARTES_WEBHOOK_SECRET=replace-me

# Outbound API credentials
MANDALA_SAMSARA_API_TOKEN=
MANDALA_SAMSARA_BASE_URL=https://api.samsara.com
MANDALA_SAMSARA_OUTBOUND_ENABLED=0  # Set to 1 to push enrichment back to Samsara dashboard
MANDALA_DESCARTES_API_KEY=
MANDALA_DESCARTES_BASE_URL=https://gln.descartes.com

# --- CargoWise (WiseTech eAdaptor) ---
MANDALA_CARGOWISE_WEBHOOK_SECRET=replace-me
MANDALA_CARGOWISE_EADAPTOR_URL=
MANDALA_CARGOWISE_USERNAME=
MANDALA_CARGOWISE_PASSWORD=
MANDALA_CARGOWISE_ORGANIZATION_CODE=

# --- Load-board auto-posting (Feature 5) ---
# Strictly opt-in. Set to 1 only when DAT creds are configured.
MANDALA_LOADBOARD_ENABLED=0
MANDALA_LOADBOARD_POST_DEFAULT_RADIUS_MI=250
MANDALA_LOADBOARD_POST_TTL_HOURS=24

# DAT One (OAuth2 client credentials)
MANDALA_DAT_CLIENT_ID=
MANDALA_DAT_CLIENT_SECRET=

# --- Rail (optional) ---
# Vizion API covers UP, BNSF, CSX, NS, CN, CPKC — no LOA required.
# Free trial: https://www.vizionapi.com
MANDALA_VIZION_API_KEY=

# --- Aurora (autonomous trucks, partnership required) ---
# See docs/integrations/aurora.md for integration pattern
# Requires Aurora Partner Program: https://aurora.tech/partners
# MANDALA_AURORA_ENABLED=0
# MANDALA_AURORA_WEBHOOK_SECRET=
# MANDALA_AURORA_API_KEY=
# MANDALA_AURORA_BEACON_ENABLED=0
# MANDALA_AURORA_INTELLIGENCE_SHARING=1

# --- GS1 EPCIS 2.0 (global standard for supply chain traceability) ---
# See docs/standards/epcis.md for integration pattern
# EPCIS capture endpoint (e.g., http://epcis-server:8080/capture)
# MANDALA_EPCIS_ENABLED=0
# MANDALA_EPCIS_CAPTURE_URL=
# MANDALA_EPCIS_QUERY_URL=
# MANDALA_EPCIS_GLN=  # GS1 Global Location Number (your organization)

# --- IOF Supply Chain Reference Ontology (SCRO) alignment ---
# See docs/standards/iof-mapping.md for alignment document
# MANDALA_IOF_ENABLED=0  # Add IOF URIs to events for semantic web compatibility
# MANDALA_IOF_BASE_URI=https://w3id.org/mandala/iof/

# Logging
MANDALA_LOG_LEVEL=INFO
