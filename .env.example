MANDALA_REDIS_URL=redis://localhost:6379/0
MANDALA_DATABASE_URL=postgresql+asyncpg://mandala:mandala@localhost:5432/mandala

# Webhook HMAC secrets (configure in Samsara/Descartes admin consoles)
MANDALA_SAMSARA_WEBHOOK_SECRET=replace-me
MANDALA_DESCARTES_WEBHOOK_SECRET=replace-me

# Outbound API credentials
MANDALA_SAMSARA_API_TOKEN=
MANDALA_SAMSARA_BASE_URL=https://api.samsara.com
MANDALA_SAMSARA_OUTBOUND_ENABLED=0  # Set to 1 to push enrichment back to Samsara dashboard
MANDALA_DESCARTES_API_KEY=
MANDALA_DESCARTES_BASE_URL=https://gln.descartes.com

# --- CargoWise (WiseTech eAdaptor) ---
MANDALA_CARGOWISE_WEBHOOK_SECRET=replace-me
MANDALA_CARGOWISE_EADAPTOR_URL=
MANDALA_CARGOWISE_USERNAME=
MANDALA_CARGOWISE_PASSWORD=
MANDALA_CARGOWISE_ORGANIZATION_CODE=

# --- Load-board auto-posting (Feature 5) ---
# Strictly opt-in. Set to 1 only when DAT creds are configured.
MANDALA_LOADBOARD_ENABLED=0
MANDALA_LOADBOARD_POST_DEFAULT_RADIUS_MI=250
MANDALA_LOADBOARD_POST_TTL_HOURS=24

# DAT One (OAuth2 client credentials)
MANDALA_DAT_CLIENT_ID=
MANDALA_DAT_CLIENT_SECRET=

# --- Rail (optional) ---
# Vizion API covers UP, BNSF, CSX, NS, CN, CPKC — no LOA required.
# Free trial: https://www.vizionapi.com
MANDALA_VIZION_API_KEY=

# --- Aurora (autonomous trucks, partnership required) ---
# See docs/integrations/aurora.md for integration pattern
# Requires Aurora Partner Program: https://aurora.tech/partners
# MANDALA_AURORA_ENABLED=0
# MANDALA_AURORA_WEBHOOK_SECRET=
# MANDALA_AURORA_API_KEY=
# MANDALA_AURORA_BEACON_ENABLED=0
# MANDALA_AURORA_INTELLIGENCE_SHARING=1

# --- SAP (Transportation Management, Extended Warehouse Management) ---
# See docs/integrations/sap.md for integration pattern
# MANDALA_SAP_ENABLED=0
# MANDALA_SAP_HOST=
# MANDALA_SAP_PORT=44300
# MANDALA_SAP_CLIENT_ID=
# MANDALA_SAP_CLIENT_SECRET=

# --- Port-of-Entry (POE) geofencing for cross-border operations ---
# Configurable POE geofences for customs visibility alerts
# Format: JSON string with POE name as key, lat/lon/radius as value
# Example for US-Mexico border (Laredo, Otay Mesa, Eagle Pass):
# MANDALA_POE_GEOFENCES='{"Laredo": {"latitude": 27.5062, "longitude": -99.5075, "radius_meters": 5000}, "Otay Mesa": {"latitude": 32.5407, "longitude": -116.9379, "radius_meters": 5000}, "Eagle Pass": {"latitude": 28.9089, "longitude": -100.4987, "radius_meters": 5000}}'
# When a truck enters a POE geofence in Samsara, Mandala emits TRUCK_POE_ENTERED event
# When a truck exits a POE geofence in Samsara, Mandala emits TRUCK_POE_EXITED event
# MANDALA_POE_GEOFENCES=

# Logging
MANDALA_LOG_LEVEL=INFO

# --- Apache Iceberg Event Log (Feature 1) ---
# Permanent event storage on object storage (S3/GCS/Azure)
# Separates ephemeral Redis Streams bus from permanent Iceberg log
# MANDALA_EVENT_LOG_ENABLED=0
# MANDALA_ICEBERG_CATALOG=rest
# MANDALA_ICEBERG_CATALOG_URI=http://localhost:8181
# MANDALA_ICEBERG_WAREHOUSE=s3://mandala-events/
# MANDALA_ICEBERG_TABLE=mandala.events
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Zero-Knowledge Proofs (Feature 2) ---
# Privacy-preserving verification for insurance/customs/audits
# MANDALA_ZK_ENABLED=0
# MANDALA_ZK_MAX_CONCURRENT_PROOFS=4
# MANDALA_ZK_CIRCUIT_PATH=/opt/mandala/zk/circuits/
# MANDALA_ZK_PROVING_KEY=/opt/mandala/zk/keys/cold_chain_breach.pk
# MANDALA_ZK_VERIFICATION_KEY=/opt/mandala/zk/keys/cold_chain_breach.vk
# MANDALA_ZK_REMOTE_VERIFIER_ENDPOINT=https://insurer.example.com/api/v1/zk/verify
